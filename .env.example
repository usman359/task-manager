# Server
PORT=3001
# Optional: require this value in X-API-Key on all /tasks requests
# API_KEY=your-secret
# Default: server/data/tasks.db
# DATABASE_PATH=./data/tasks.db

# Client (Vite) — only variables prefixed with VITE_ are exposed to the browser
# Optional: if API_KEY is set, must match here for dev/proxy
# VITE_API_KEY=your-secret
# VITE_API_BASE=  leave empty in dev; set full origin if the API is on another host
