# --- Server
PORT=3002
# Optional bonus: if set, every /tasks request must include header: X-API-Key: <value>
# API_KEY=your-secret
# Default SQLite file: server/data/tasks.db
# DATABASE_PATH=./data/tasks.db

# --- Client (Vite; only VITE_* is exposed in the browser)
# If you set API_KEY on the server, set the same value here for dev and production UI:
# VITE_API_KEY=your-secret
# If the API is on another origin (rare in this repo), set:
# VITE_API_BASE=https://api.example.com
